package com.shengwei.tushuguanli.service.impl;

import com.baomidou.mybatisplus.core.conditions.query.LambdaQueryWrapper;
import com.shengwei.tushuguanli.entity.*;
import com.shengwei.tushuguanli.mapper.*;
import com.shengwei.tushuguanli.service.StatisticsService;
import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.stereotype.Service;

import java.math.BigDecimal;
import java.time.LocalDate;
import java.time.LocalDateTime;
import java.time.YearMonth;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.stream.Collectors;

/**
 * 数据统计服务实现类
 */
@Service
public class StatisticsServiceImpl implements StatisticsService {

    @Autowired
    private TradeOrderMapper tradeOrderMapper;

    @Autowired
    private MemberInfoMapper memberInfoMapper;

    @Autowired
    private BookInfoMapper bookInfoMapper;

    @Autowired
    private InventoryMapper inventoryMapper;

    @Autowired
    private DonationApplyMapper donationApplyMapper;

    @Autowired
    private DonationAcceptMapper donationAcceptMapper;

    @Override
    public Map<String, Object> salesStatistics(LocalDate startDate, LocalDate endDate) {
        Map<String, Object> result = new HashMap<>();

        // 查询订单数据
        LambdaQueryWrapper<TradeOrder> wrapper = new LambdaQueryWrapper<>();
        wrapper.eq(TradeOrder::getOrderStatus, 4); // 已完成订单
        wrapper.eq(TradeOrder::getPaymentStatus, 1); // 已支付

        if (startDate != null) {
            wrapper.ge(TradeOrder::getCreateTime, startDate.atStartOfDay());
        }
        if (endDate != null) {
            wrapper.le(TradeOrder::getCreateTime, endDate.atTime(23, 59, 59));
        }

        List<TradeOrder> orders = tradeOrderMapper.selectList(wrapper);

        // 计算总销售额
        BigDecimal totalSales = orders.stream()
                .map(TradeOrder::getActualAmount)
                .filter(amount -> amount != null)
                .reduce(BigDecimal.ZERO, BigDecimal::add);

        // 计算订单数量
        long orderCount = orders.size();

        // 计算平均订单金额
        BigDecimal avgOrderAmount = orderCount > 0 ?
                totalSales.divide(BigDecimal.valueOf(orderCount), 2, BigDecimal.ROUND_HALF_UP) :
                BigDecimal.ZERO;

        result.put("totalSales", totalSales);
        result.put("orderCount", orderCount);
        result.put("avgOrderAmount", avgOrderAmount);
        result.put("startDate", startDate);
        result.put("endDate", endDate);

        return result;
    }

    @Override
    public Map<String, Object> orderStatistics(LocalDate startDate, LocalDate endDate) {
        Map<String, Object> result = new HashMap<>();

        LambdaQueryWrapper<TradeOrder> wrapper = new LambdaQueryWrapper<>();
        if (startDate != null) {
            wrapper.ge(TradeOrder::getCreateTime, startDate.atStartOfDay());
        }
        if (endDate != null) {
            wrapper.le(TradeOrder::getCreateTime, endDate.atTime(23, 59, 59));
        }

        // 各状态订单数量
        long totalOrders = tradeOrderMapper.selectCount(wrapper);

        long pendingPaymentCount = tradeOrderMapper.selectCount(
                wrapper.clone().eq(TradeOrder::getOrderStatus, 1));
        long paidPendingShipCount = tradeOrderMapper.selectCount(
                wrapper.clone().eq(TradeOrder::getOrderStatus, 2));
        long shippedCount = tradeOrderMapper.selectCount(
                wrapper.clone().eq(TradeOrder::getOrderStatus, 3));
        long completedCount = tradeOrderMapper.selectCount(
                wrapper.clone().eq(TradeOrder::getOrderStatus, 4));
        long cancelledCount = tradeOrderMapper.selectCount(
                wrapper.clone().eq(TradeOrder::getOrderStatus, 0));

        result.put("totalOrders", totalOrders);
        result.put("pendingPaymentCount", pendingPaymentCount);
        result.put("paidPendingShipCount", paidPendingShipCount);
        result.put("shippedCount", shippedCount);
        result.put("completedCount", completedCount);
        result.put("cancelledCount", cancelledCount);

        return result;
    }

    @Override
    public Map<String, Object> memberStatistics(LocalDate startDate, LocalDate endDate) {
        Map<String, Object> result = new HashMap<>();

        LambdaQueryWrapper<MemberInfo> wrapper = new LambdaQueryWrapper<>();
        if (startDate != null) {
            wrapper.ge(MemberInfo::getCreateTime, startDate.atStartOfDay());
        }
        if (endDate != null) {
            wrapper.le(MemberInfo::getCreateTime, endDate.atTime(23, 59, 59));
        }

        // 会员总数
        long totalMembers = memberInfoMapper.selectCount(wrapper);

        // 各等级会员数量
        long bronzeCount = memberInfoMapper.selectCount(
                wrapper.clone().eq(MemberInfo::getMemberLevel, 1));
        long silverCount = memberInfoMapper.selectCount(
                wrapper.clone().eq(MemberInfo::getMemberLevel, 2));
        long goldCount = memberInfoMapper.selectCount(
                wrapper.clone().eq(MemberInfo::getMemberLevel, 3));
        long platinumCount = memberInfoMapper.selectCount(
                wrapper.clone().eq(MemberInfo::getMemberLevel, 4));
        long diamondCount = memberInfoMapper.selectCount(
                wrapper.clone().eq(MemberInfo::getMemberLevel, 5));

        result.put("totalMembers", totalMembers);
        result.put("bronzeCount", bronzeCount);
        result.put("silverCount", silverCount);
        result.put("goldCount", goldCount);
        result.put("platinumCount", platinumCount);
        result.put("diamondCount", diamondCount);

        return result;
    }

    @Override
    public Map<String, Object> inventoryStatistics() {
        Map<String, Object> result = new HashMap<>();

        // 图书总数
        long totalBooks = bookInfoMapper.selectCount(null);

        // 库存总量
        LambdaQueryWrapper<Inventory> inventoryWrapper = new LambdaQueryWrapper<>();
        List<Inventory> inventories = inventoryMapper.selectList(inventoryWrapper);
        Integer totalStock = inventories.stream()
                .map(Inventory::getStockQuantity)
                .filter(stock -> stock != null)
                .reduce(0, Integer::sum);

        // 低库存图书数量
        long lowStockCount = bookInfoMapper.selectCount(
                new LambdaQueryWrapper<BookInfo>()
                        .lt(BookInfo::getStockCount, 10));

        // 上下架统计
        long onShelfCount = bookInfoMapper.selectCount(
                new LambdaQueryWrapper<BookInfo>()
                        .eq(BookInfo::getShelfStatus, 1));
        long offShelfCount = bookInfoMapper.selectCount(
                new LambdaQueryWrapper<BookInfo>()
                        .eq(BookInfo::getShelfStatus, 0));

        result.put("totalBooks", totalBooks);
        result.put("totalStock", totalStock);
        result.put("lowStockCount", lowStockCount);
        result.put("onShelfCount", onShelfCount);
        result.put("offShelfCount", offShelfCount);

        return result;
    }

    @Override
    public Map<String, Object> donationStatistics(LocalDate startDate, LocalDate endDate) {
        Map<String, Object> result = new HashMap<>();

        LambdaQueryWrapper<DonationApply> applyWrapper = new LambdaQueryWrapper<>();
        LambdaQueryWrapper<DonationAccept> acceptWrapper = new LambdaQueryWrapper<>();

        if (startDate != null) {
            applyWrapper.ge(DonationApply::getCreateTime, startDate.atStartOfDay());
            acceptWrapper.ge(DonationAccept::getCreateTime, startDate.atStartOfDay());
        }
        if (endDate != null) {
            applyWrapper.le(DonationApply::getCreateTime, endDate.atTime(23, 59, 59));
            acceptWrapper.le(DonationAccept::getCreateTime, endDate.atTime(23, 59, 59));
        }

        // 捐赠申请统计
        long totalApplyCount = donationApplyMapper.selectCount(applyWrapper);
        long pendingApplyCount = donationApplyMapper.selectCount(
                applyWrapper.clone().eq(DonationApply::getAuditStatus, 1));
        long approvedApplyCount = donationApplyMapper.selectCount(
                applyWrapper.clone().eq(DonationApply::getAuditStatus, 2));
        long rejectedApplyCount = donationApplyMapper.selectCount(
                applyWrapper.clone().eq(DonationApply::getAuditStatus, 3));

        // 捐赠验收统计
        long totalAcceptCount = donationAcceptMapper.selectCount(acceptWrapper);
        long pendingAcceptCount = donationAcceptMapper.selectCount(
                acceptWrapper.clone().eq(DonationAccept::getStatus, 1));
        long acceptedCount = donationAcceptMapper.selectCount(
                acceptWrapper.clone().eq(DonationAccept::getStatus, 2));
        long completedAcceptCount = donationAcceptMapper.selectCount(
                acceptWrapper.clone().eq(DonationAccept::getStatus, 3));

        result.put("totalApplyCount", totalApplyCount);
        result.put("pendingApplyCount", pendingApplyCount);
        result.put("approvedApplyCount", approvedApplyCount);
        result.put("rejectedApplyCount", rejectedApplyCount);
        result.put("totalAcceptCount", totalAcceptCount);
        result.put("pendingAcceptCount", pendingAcceptCount);
        result.put("acceptedCount", acceptedCount);
        result.put("completedAcceptCount", completedAcceptCount);

        return result;
    }

    @Override
    public List<Map<String, Object>> bookSalesRanking(LocalDate startDate, LocalDate endDate, Integer limit) {
        // 这里需要连接订单项表查询，简化实现返回空列表
        // 实际项目中应该使用复杂的SQL查询
        return new ArrayList<>();
    }

    @Override
    public List<Map<String, Object>> donorRanking(LocalDate startDate, LocalDate endDate, Integer limit) {
        // 这里需要连接捐赠相关表查询，简化实现返回空列表
        // 实际项目中应该使用复杂的SQL查询
        return new ArrayList<>();
    }

    @Override
    public List<Map<String, Object>> monthlySalesTrend(Integer year) {
        List<Map<String, Object>> result = new ArrayList<>();

        if (year == null) {
            year = LocalDate.now().getYear();
        }

        for (int month = 1; month <= 12; month++) {
            YearMonth yearMonth = YearMonth.of(year, month);
            LocalDateTime startOfMonth = yearMonth.atDay(1).atStartOfDay();
            LocalDateTime endOfMonth = yearMonth.atEndOfMonth().atTime(23, 59, 59);

            LambdaQueryWrapper<TradeOrder> wrapper = new LambdaQueryWrapper<>();
            wrapper.eq(TradeOrder::getOrderStatus, 4);
            wrapper.eq(TradeOrder::getPaymentStatus, 1);
            wrapper.ge(TradeOrder::getCreateTime, startOfMonth);
            wrapper.le(TradeOrder::getCreateTime, endOfMonth);

            List<TradeOrder> orders = tradeOrderMapper.selectList(wrapper);
            BigDecimal monthlySales = orders.stream()
                    .map(TradeOrder::getActualAmount)
                    .filter(amount -> amount != null)
                    .reduce(BigDecimal.ZERO, BigDecimal::add);

            Map<String, Object> monthData = new HashMap<>();
            monthData.put("month", month);
            monthData.put("monthStr", yearMonth.getMonthValue() + "月");
            monthData.put("sales", monthlySales);
            monthData.put("orderCount", orders.size());

            result.add(monthData);
        }

        return result;
    }

    @Override
    public List<Map<String, Object>> memberGrowthTrend(Integer year) {
        List<Map<String, Object>> result = new ArrayList<>();

        if (year == null) {
            year = LocalDate.now().getYear();
        }

        for (int month = 1; month <= 12; month++) {
            YearMonth yearMonth = YearMonth.of(year, month);
            LocalDateTime startOfMonth = yearMonth.atDay(1).atStartOfDay();
            LocalDateTime endOfMonth = yearMonth.atEndOfMonth().atTime(23, 59, 59);

            LambdaQueryWrapper<MemberInfo> wrapper = new LambdaQueryWrapper<>();
            wrapper.ge(MemberInfo::getCreateTime, startOfMonth);
            wrapper.le(MemberInfo::getCreateTime, endOfMonth);

            long monthlyNewMembers = memberInfoMapper.selectCount(wrapper);

            Map<String, Object> monthData = new HashMap<>();
            monthData.put("month", month);
            monthData.put("monthStr", yearMonth.getMonthValue() + "月");
            monthData.put("newMembers", monthlyNewMembers);

            result.add(monthData);
        }

        return result;
    }
}